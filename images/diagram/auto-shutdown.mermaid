sequenceDiagram
    participant U as User
    participant K as Klipper
    participant APO as Auto Power Off
    participant T as Timer
    participant M as Moonraker API
    participant P as Power Device

    Note over K,APO: Print completed
    K->>APO: _handle_print_complete()
    
    alt Auto power off enabled
        APO->>APO: Log "starting power-off timer"
        APO->>T: Start idle timer
        
        Note over APO,T: Wait for idle period
        T-->>APO: _check_conditions()
        
        APO->>APO: Check printer state
        
        alt Print in progress or resumed
            APO->>APO: Log "print in progress, canceling shutdown"
            APO->>T: Cancel timer (NEVER)
        else Printer not idle
            APO->>APO: Log "printer not idle, postponing shutdown"
            APO->>T: Reschedule check (+60s)
        else Temperatures too high
            APO->>APO: Log "temperatures too high, postponing shutdown"
            APO->>T: Reschedule check (+60s)
        else Conditions met
            APO->>APO: Log "conditions met, powering off"
            APO->>APO: _power_off()
            
            opt Network device connectivity test
                APO->>P: Test connectivity
                alt Device unreachable
                    APO->>APO: Raise NetworkDeviceUnreachableError
                end
            end
            
            APO->>APO: _prepare_mcu_for_shutdown()
            APO->>K: TURN_OFF_HEATERS
            
            alt Moonraker integration & not forced direct
                APO->>M: POST /machine/device_power/device (action=off)
                alt Moonraker API success
                    M->>P: Power off device
                    APO->>APO: Log "powered off via Moonraker"
                else Failure after retries
                    APO->>APO: Log "falling back to direct method"
                    APO->>APO: _power_off_direct()
                end
            else Direct method
                APO->>APO: _power_off_direct()
                
                alt set_power available
                    APO->>P: set_power(0)
                else turn_off available
                    APO->>P: turn_off()
                else power_off available
                    APO->>P: power_off()
                else GCODE available
                    APO->>K: POWER_OFF
                else
                    APO->>APO: Raise PowerOffError
                end
            end
        end
    else Auto power off disabled
        APO->>APO: Log "auto power off is disabled"
    end
